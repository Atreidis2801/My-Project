import numpy as np

class GlucoseSensor:
    def __init__(self):
        # Initial estimate of glucose (mg/dL)
        self.estimate = 100.0
        self.error_estimate = 2.0
        self.error_measure = 5.0  # Noise from the sensor

    def kalman_filter(self, measurement):
        # Prediction update
        kalman_gain = self.error_estimate / (self.error_estimate + self.error_measure)
        self.estimate = self.estimate + kalman_gain * (measurement - self.estimate)
        self.error_estimate = (1 - kalman_gain) * self.error_estimate
        return self.estimate

# Simulation
sensor = GlucoseSensor()
raw_readings = [105, 110, 95, 120, 115] # Simulated noisy voltage readings converted to mg/dL

print(f"Processing Data for Reg No: 25BOE10040...")
print("-" * 40)
for val in raw_readings:
    filtered = sensor.kalman_filter(val)
    status = "Normal" if 70 <= filtered <= 140 else "Alert"
    print(f"Raw: {val} | Filtered: {filtered:.2f} mg/dL | Status: {status}")
